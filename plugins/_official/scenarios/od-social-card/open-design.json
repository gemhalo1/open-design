{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "od-social-card",
  "title": "Social card (default scenario)",
  "version": "0.1.0",
  "description": "Default scenario plugin for platform-ready social cards, carousels, covers, threads, stories, and launch visuals.",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/scenarios/od-social-card",
  "tags": [
    "scenario",
    "first-party",
    "social-card",
    "carousel",
    "x",
    "linkedin",
    "instagram",
    "rednote",
    "wechat"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "scenario": "social-card",
    "mode": "social-card",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./assets/template.html"
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./assets/template.html",
        "./references/layouts.md",
        "./references/checklist.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "discovery",
          "atoms": [
            "discovery-question-form"
          ]
        },
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "useCase": {
      "query": {
        "en": "Create platform-ready social design for {{audience}}. Platform: {{platform}}. Layout: {{layout}}. Content brief: {{content}}. Palette direction: {{palette}}. Use {{designSystem}} as brand direction. Build from `assets/template.html` and choose the closest pattern from `references/layouts.md`; output export-ready static frames with strong typography and crop-safe composition.",
        "zh-CN": "为 {{audience}} 创建可发布的社媒设计。平台：{{platform}}。版式：{{layout}}。内容简述：{{content}}。配色方向：{{palette}}。品牌方向使用 {{designSystem}}。基于 `assets/template.html` 并从 `references/layouts.md` 选择最接近的模式；输出可导出的静态画板，强调强排版和安全裁切。"
      },
      "exampleOutputs": [
        {
          "path": "./assets/template.html",
          "title": "Social card seed"
        }
      ]
    },
    "inputs": [
      {
        "name": "platform",
        "label": "Platform",
        "type": "select",
        "required": true,
        "options": [
          "Twitter / X",
          "Threads",
          "LinkedIn",
          "Instagram story",
          "Xiaohongshu / Rednote",
          "WeChat cover",
          "multi-platform"
        ],
        "default": "multi-platform"
      },
      {
        "name": "layout",
        "label": "Layout",
        "type": "select",
        "required": true,
        "options": [
          "single post card",
          "carousel",
          "quote card",
          "data/chart card",
          "story frame",
          "cover pair"
        ],
        "default": "single post card"
      },
      {
        "name": "content",
        "label": "Content brief",
        "type": "string",
        "required": true,
        "placeholder": "launch note, hot take, data point, tutorial, quote",
        "default": "the user's social brief"
      },
      {
        "name": "audience",
        "label": "Audience",
        "type": "string",
        "required": true,
        "placeholder": "social feed viewers",
        "default": "social feed viewers"
      },
      {
        "name": "palette",
        "label": "Palette",
        "type": "string",
        "placeholder": "X monochrome, LinkedIn blue, editorial ink, brand palette",
        "default": "restrained platform-appropriate palette"
      },
      {
        "name": "designSystem",
        "label": "Design system",
        "type": "string",
        "placeholder": "active design system or social editorial",
        "default": "the active project design system"
      }
    ]
  }
}
