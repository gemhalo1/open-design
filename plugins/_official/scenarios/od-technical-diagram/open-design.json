{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "od-technical-diagram",
  "title": "Technical diagram (default scenario)",
  "version": "0.1.0",
  "description": "Default scenario plugin for architecture diagrams, workflow charts, RAG/agent diagrams, UML, data-flow maps, and comparison diagrams.",
  "license": "MIT",
  "author": {
    "name": "Open Design",
    "url": "https://github.com/nexu-io"
  },
  "homepage": "https://github.com/nexu-io/open-design/tree/main/plugins/_official/scenarios/od-technical-diagram",
  "tags": [
    "scenario",
    "first-party",
    "diagram",
    "architecture",
    "workflow",
    "uml",
    "data-flow",
    "infographic"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "scenario": "technical-diagram",
    "mode": "diagram",
    "surface": "web",
    "preview": {
      "type": "html",
      "entry": "./assets/template.html"
    },
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./assets/template.html",
        "./references/patterns.md",
        "./references/checklist.md"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "discovery",
          "atoms": [
            "discovery-question-form"
          ]
        },
        {
          "id": "generate",
          "atoms": [
            "file-write",
            "live-artifact"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write"
    ],
    "useCase": {
      "query": {
        "en": "Create a polished {{diagramType}} for {{audience}} explaining {{systemContext}}. Detail level: {{detailLevel}}. Visual style: {{visualStyle}}. Build an editable SVG/HTML diagram from `assets/template.html` and `references/patterns.md`; use semantic nodes, labeled arrows, clear grouping, and a legend when needed.",
        "zh-CN": "为 {{audience}} 创建一张高质量 {{diagramType}}，解释 {{systemContext}}。细节层级：{{detailLevel}}。视觉风格：{{visualStyle}}。基于 `assets/template.html` 和 `references/patterns.md` 生成可编辑 SVG/HTML 图；使用语义节点、带标签箭头、清晰分组，必要时加图例。"
      },
      "exampleOutputs": [
        {
          "path": "./assets/template.html",
          "title": "Diagram seed"
        }
      ]
    },
    "inputs": [
      {
        "name": "diagramType",
        "label": "Diagram type",
        "type": "select",
        "required": true,
        "options": [
          "architecture diagram",
          "workflow diagram",
          "RAG / agent diagram",
          "UML diagram",
          "data-flow diagram",
          "comparison diagram",
          "infographic"
        ],
        "default": "architecture diagram"
      },
      {
        "name": "systemContext",
        "label": "System context",
        "type": "string",
        "required": true,
        "placeholder": "request flow, product workflow, data pipeline",
        "default": "the user's system or workflow brief"
      },
      {
        "name": "audience",
        "label": "Audience",
        "type": "string",
        "required": true,
        "placeholder": "engineering and product readers",
        "default": "engineering and product readers"
      },
      {
        "name": "detailLevel",
        "label": "Detail level",
        "type": "select",
        "options": [
          "executive overview",
          "product doc",
          "engineering handoff",
          "implementation detail"
        ],
        "default": "product doc"
      },
      {
        "name": "visualStyle",
        "label": "Visual style",
        "type": "select",
        "options": [
          "clean product-doc",
          "blueprint",
          "dark terminal",
          "warm editorial",
          "minimal Notion"
        ],
        "default": "clean product-doc"
      }
    ]
  }
}
